{
  "name": "keeptrack-backend",
  "version": "0.0.1",
  "description": "API backend of the keepTrack application",
  "repository": {
    "type": "git",
    "url": "keepTrack-backend"
  },
  "license": "MIT",
  "author": "Mark Mozer",
  "type": "module",
  "main": "app.js",
  "scripts": {
    "test:unit": "vitest run -c vitest.unit.config.js",
    "test:int": "dotenv -e .env.test -- vitest run -c vitest.int.config.js",
    "test:watch": "vitest -c vitest.unit.config.js",
    "db:migrate:test": "dotenv -e .env.test -- prisma migrate deploy",
    "provision:tenant": "node src/interface/cli/provisionTenant.cli.js"
  },
  "devDependencies": {
    "@types/dotenv": "^6.1.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.5",
    "dotenv-cli": "^11.0.0",
    "prisma": "^7.4.2",
    "supertest": "^7.2.2",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@azure/identity": "^4.13.0",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "ioredis": "^5.10.0",
    "morgan": "^1.10.1",
    "pg": "^8.20.0"
  }
}
